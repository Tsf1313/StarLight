# Environment template - Copy to .env.production and fill in actual values

# === Cloudflare Worker API ===
VITE_API_URL=https://api.eventflow.hamstersame.org

# === Local Development ===
# Use this for local testing (default if VITE_API_URL not set):
# VITE_API_URL=http://localhost:3000

# === App Info ===
VITE_APP_NAME=EventFlow
VITE_APP_VERSION=1.0.0

# === Feature Flags ===
VITE_ENABLE_POLLS=true
VITE_POLL_INTERVAL_MS=5000
